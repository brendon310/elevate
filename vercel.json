{
  "crons": [
    {
      "path": "/api/cron-push",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/emails/reengagement",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/emails/weekly-digest",
      "schedule": "0 8 * * 1"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
